{
    "version": 2,
    "installCommand": "cd InterpretersDashboard && npm install",
    "buildCommand": "cd InterpretersDashboard && npm run build",
    "outputDirectory": "InterpretersDashboard/dist",
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}
