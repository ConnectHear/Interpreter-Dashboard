{
    "version": 2,
    "installCommand": "cd backend && npm install && cd ../InterpretersDashboard && npm install",
    "buildCommand": "cd InterpretersDashboard && npm run build",
    "outputDirectory": "InterpretersDashboard/dist",
    "env": {
        "TZ": "Asia/Karachi",
        "JWT_SECRET": "ch_super_secret_key_change_this_in_vercel_env"
    },
    "functions": {
        "api/index.js": {
            "maxDuration": 30,
            "includeFiles": "backend/**"
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/((?!api).*)",
            "destination": "/index.html"
        }
    ]
}